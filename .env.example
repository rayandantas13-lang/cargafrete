# =============================================================================
# CargaFrete - Variáveis de Ambiente (exemplo)
# =============================================================================
# Copie este arquivo para `.env.local` (que NÃO é versionado) e preencha com os
# seus valores reais, OU cadastre estas mesmas variáveis no provedor de
# hospedagem (Vercel, Netlify, etc.).
#
# Como todas começam com NEXT_PUBLIC_, elas são embutidas no build do Next.js.
# Isso significa que, depois de configuradas, QUALQUER dispositivo que abrir o
# app (celular, tablet, desktop) já terá a conexão com a planilha pré-carregada
# — sem que ninguém precise digitar nada manualmente.
# =============================================================================

# URL do seu Google Apps Script (a URL que termina em /exec).
# É o campo "API Key / Apps Script URL" da tela Admin.
NEXT_PUBLIC_GOOGLE_SHEETS_API_KEY="https://script.google.com/macros/s/SUA_URL_DO_APPS_SCRIPT_AQUI/exec"

# ID da Planilha do Google Sheets (o trecho longo na URL da planilha).
NEXT_PUBLIC_SPREADSHEET_ID="SEU_SPREADSHEET_ID_AQUI"
